# Server
PORT=3000
API_TOKEN=

# Nutalk Core API (where to send replies/tags)
NUTALK_API_URL=http://localhost:3001

# Storage: leave empty for in-memory, or set for production
DATABASE_URL=              # postgres://user:pass@localhost:5432/schedulebot
REDIS_URL=                 # redis://localhost:6379

# LLM Fallback (OpenRouter)
LLM_API_KEY=
LLM_MODEL=openai/gpt-4o-mini

# Admin phone numbers (comma-separated)
ADMIN_PHONES=5511999999999,5511888888888
